{
  "name": "openclaw-render",
  "version": "2.0.1",
  "private": true,
  "description": "OpenClaw on Render — one-click deploy, powered by @chrysb/alphaclaw (jhol131 fork: openclaw pinned 2026.6.11)",
  "scripts": {
    "dev": "docker compose up --build",
    "dev:stop": "docker compose down",
    "dev:clean": "docker compose down -v",
    "dev:logs": "docker compose logs -f",
    "dev:shell": "docker compose exec openclaw bash"
  },
  "dependencies": {
    "@chrysb/alphaclaw": "0.9.18",
    "openclaw": "2026.6.11"
  },
  "overrides": {
    "openclaw": "2026.6.11"
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
